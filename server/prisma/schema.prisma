generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  name     String?
  email    String @unique
  password String

  todos      Todo[]
  focusSessions FocusSession[]
  refreshTokens RefreshToken[]
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  priority    String   @default("medium")
  dueDate     DateTime?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtasks Subtask[]
  focusSessions FocusSession[]

  @@index([userId])
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Todo @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model FocusSession {
  id        String   @id @default(cuid())
  userId    String
  todoId    String?
  duration  Int
  completed Boolean  @default(false)
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  todo Todo? @relation(fields: [todoId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([todoId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
